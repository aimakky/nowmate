NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Sentry (エラー監視 / source map upload) ─────────────────────
# 1) https://sentry.io でアカウント作成 → Next.js プロジェクト作成
# 2) Settings → Client Keys (DSN) から DSN をコピー
# 3) Settings → Auth Tokens から org:read + project:releases 権限の token を発行
#
# NEXT_PUBLIC_SENTRY_DSN
#   client / server / edge すべての init で読まれる。
#   未設定なら Sentry は完全 no-op (dev / E2E スモークでは設定しないでよい)。
#
# SENTRY_AUTH_TOKEN
#   build 時の source map upload で使用。Vercel build 環境のみで必要。
#   ローカル / Playwright CI には設定しなくてよい。
#
# SENTRY_ORG / SENTRY_PROJECT
#   Sentry 組織 / プロジェクトの slug。next.config.js withSentryConfig で参照。
#
# 接続確認手順 (DSN を設定して dev server 起動後):
#   ブラウザ DevTools コンソールで `throw new Error('sentry-test')` を実行 →
#   Sentry dashboard の Issues に "sentry-test" が現れれば OK。
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── LiveKit (SFU 通話基盤) ───────────────────────────────────
# 1) https://cloud.livekit.io/ で Project を作成
# 2) Settings → Keys から API Key / Secret を発行
# 3) Settings → Project URL を控える（wss://xxx.livekit.cloud）
# サーバー側のみで使用（API Key/Secret はクライアントに漏らさない）
LIVEKIT_API_KEY=APIxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# クライアントから wss 接続するため NEXT_PUBLIC_ で公開（接続 URL は秘密ではない）
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
