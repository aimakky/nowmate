NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# /admin / /admin/profiles 等の管理画面へアクセス可能な Supabase user.id を
# カンマ区切りで列挙する。空・未設定・UUID 形式でない文字列はすべて拒否される。
# 例: ADMIN_USER_IDS=11111111-2222-3333-4444-555555555555,66666666-7777-8888-9999-000000000000
ADMIN_USER_IDS=
