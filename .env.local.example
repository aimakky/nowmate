NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── LiveKit (SFU 通話基盤) ───────────────────────────────────
# 1) https://cloud.livekit.io/ で Project を作成
# 2) Settings → Keys から API Key / Secret を発行
# 3) Settings → Project URL を控える（wss://xxx.livekit.cloud）
# サーバー側のみで使用（API Key/Secret はクライアントに漏らさない）
LIVEKIT_API_KEY=APIxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# クライアントから wss 接続するため NEXT_PUBLIC_ で公開（接続 URL は秘密ではない）
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
