# Playwright E2E テスト用の環境変数サンプル。
#
# このファイルは git にコミットされてもよい「サンプル」です。
# 実際の値は `.env.test.local` に書いてください (gitignore 済)。
#
# Phase 1 (現在) のスモークテストは env なしでも動きます。
# Phase 2 で認証突破テストを追加するときに以下の変数が必要になります。

# テスト専用 Supabase ユーザー (staging 環境で作成すること、本番は絶対に使わない)
PLAYWRIGHT_TEST_EMAIL=playwright_test_user@yvoice-test.invalid
PLAYWRIGHT_TEST_PASSWORD=replace-with-strong-password

# Playwright が起動する dev server のポート (デフォルト 3000)
# PLAYWRIGHT_PORT=3000

# baseURL を上書きしたい場合 (デフォルト http://localhost:${PLAYWRIGHT_PORT})
# PLAYWRIGHT_BASE_URL=http://localhost:3000
